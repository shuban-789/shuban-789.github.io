---
import type { CollectionEntry } from 'astro:content';
import TagChip from '../components/TagChip.astro';
import SiteLayout from './SiteLayout.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, tags } = Astro.props;
---

<SiteLayout title={title} description={description}>
	<article class="article-shell">
		<section class="article-hero panel">
			<div class="article-hero__copy">
				<h1>{title}</h1>
				<p class="article-description">{description}</p>
				<div class="tag-row">
					{tags.map((tag) => <TagChip tag={tag} />)}
				</div>
			</div>
		</section>

		<section class="article-panel panel">
			<div class="article-prose">
				<slot />
			</div>
		</section>
	</article>
</SiteLayout>
