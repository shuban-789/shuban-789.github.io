---
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_CONFIG } from '../site.config';

interface Props {
	title?: string;
	description?: string;
	image?: ImageMetadata;
	pageClass?: string;
}

const { title, description, image, pageClass = '' } = Astro.props;
const pageTitle = title?.trim() || SITE_CONFIG.title;
const pageDescription = description?.trim() || SITE_CONFIG.description;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} image={image} />
	</head>
	<body class={pageClass}>
		<div class="page-frame">
			<Header />
			<main class="page-content">
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
