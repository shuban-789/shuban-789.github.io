---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_CONFIG } from '../site.config';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	pageClass?: string;
}

const { title, description, image, pageClass = '' } = Astro.props;
const pageTitle = title?.trim() || SITE_CONFIG.title;
const pageDescription = description?.trim() || SITE_CONFIG.description;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} image={image} />
	</head>
	<body class={pageClass}>
		<div class="page-frame">
			<Header />
			<main class="page-content">
				<slot />
			</main>
			<Footer />
		</div>
		<script>
			import { annotate } from 'rough-notation';

			const annotations = [];
			const linkHighlightSelector =
				'.article-prose a, .home-body a, .article-description a, .page-links a, .home-tagline a, .home-location a';
			const navAnnotationSelector = '.nav-links [data-nav-link].active';
			const inlineHighlightParents = new Set(['STRONG', 'B', 'EM', 'I']);
			const highlightColor = '#bfdbf2';
			let initRunId = 0;

			const nextFrame = () =>
				new Promise((resolve) => {
					requestAnimationFrame(() => resolve());
				});

			const wait = (ms) =>
				new Promise((resolve) => {
					window.setTimeout(resolve, ms);
				});

			const getHighlightHost = (link) => {
				const parent = link.parentElement;
				if (
					parent &&
					inlineHighlightParents.has(parent.tagName) &&
					parent.childNodes.length === 1
				) {
					return parent;
				}

				return link;
			};

			const prepareHighlightHost = (link) => {
				const host = getHighlightHost(link);
				host.parentElement?.classList.add('annotation-highlight-context');
				host.classList.add('annotation-highlight-host');
				return host;
			};

			const clearHighlightMarkers = () => {
				for (const node of document.querySelectorAll('.annotation-highlight-host')) {
					node.classList.remove('annotation-highlight-host');
				}

				for (const node of document.querySelectorAll('.annotation-highlight-context')) {
					node.classList.remove('annotation-highlight-context');
				}
			};

			const clearDetachedAnnotationNodes = () => {
				for (const node of document.querySelectorAll('.rough-annotation')) {
					node.remove();
				}
			};

			const clearAnnotations = () => {
				for (const annotation of annotations.splice(0)) {
					annotation.remove();
				}

				clearDetachedAnnotationNodes();
				clearHighlightMarkers();
			};

			const buildAnnotations = () => {
				if (annotations.length > 0) {
					return;
				}

				const navLinks = Array.from(document.querySelectorAll(navAnnotationSelector));
				const highlightLinks = Array.from(document.querySelectorAll(linkHighlightSelector));

				for (const link of navLinks) {
					annotations.push(
						annotate(link, {
							type: 'circle',
							color: '#111111',
							padding: [1, 2, 1, 2],
							strokeWidth: 1.55,
							iterations: 2,
							animationDuration: 420,
							animate: true,
						}),
					);
				}

				for (const link of highlightLinks) {
					annotations.push(
						annotate(prepareHighlightHost(link), {
							type: 'highlight',
							color: highlightColor,
							multiline: true,
							animationDuration: 800,
							animate: true,
						}),
					);
				}
			};

			const showAnnotations = (animate, runId) => {
				buildAnnotations();

				for (const annotation of annotations) {
					annotation.animate = animate;
					if (animate) {
						annotation.hide();
					}
				}

				requestAnimationFrame(() => {
					if (runId !== initRunId) {
						return;
					}

					for (const annotation of annotations) {
						annotation.show();
					}
				});
			};

			const waitForFonts = async () => {
				if (!document.fonts?.ready || document.fonts.status === 'loaded') {
					return;
				}

				await Promise.race([document.fonts.ready, wait(900)]);
			};

			const waitForViewportSettling = (runId) =>
				new Promise((resolve) => {
					const viewport = window.visualViewport;
					if (!viewport) {
						window.setTimeout(resolve, 120);
						return;
					}

					let idleTimer;
					let maxTimer;

					const cleanup = () => {
						viewport.removeEventListener('resize', arm);
						window.clearTimeout(idleTimer);
						window.clearTimeout(maxTimer);
					};

					const finish = () => {
						cleanup();
						resolve();
					};

					const arm = () => {
						if (runId !== initRunId) {
							finish();
							return;
						}

						window.clearTimeout(idleTimer);
						idleTimer = window.setTimeout(finish, 160);
					};

					maxTimer = window.setTimeout(finish, 900);
					viewport.addEventListener('resize', arm, { passive: true });
					arm();
				});

			const initializeAnnotations = async (animate) => {
				const runId = ++initRunId;

				await nextFrame();
				await nextFrame();
				if (runId !== initRunId) {
					return;
				}

				await waitForFonts();
				if (runId !== initRunId) {
					return;
				}

				await waitForViewportSettling(runId);
				if (runId !== initRunId) {
					return;
				}

				await nextFrame();
				if (runId !== initRunId) {
					return;
				}

				showAnnotations(animate, runId);
			};

			initializeAnnotations(true);

			const resetAnnotationState = () => {
				initRunId += 1;
				clearAnnotations();
			};

			window.addEventListener('pageshow', (event) => {
				if (!event.persisted) {
					return;
				}

				clearAnnotations();
				initializeAnnotations(true);
			});

			window.addEventListener('pagehide', resetAnnotationState);
			window.addEventListener('beforeunload', resetAnnotationState);
		</script>
	</body>
</html>
