---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_CONFIG } from '../site.config';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	pageClass?: string;
}

const { title, description, image, pageClass = '' } = Astro.props;
const pageTitle = title?.trim() || SITE_CONFIG.title;
const pageDescription = description?.trim() || SITE_CONFIG.description;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} image={image} />
	</head>
	<body class={pageClass}>
		<div class="page-frame">
			<Header />
			<main class="page-content">
				<slot />
			</main>
			<Footer />
		</div>
		<script>
			import { annotate } from 'rough-notation';

			const annotations = [];
			const linkHighlightSelector =
				'.article-prose a, .home-body a, .article-description a, .page-links a, .home-tagline a, .home-location a';
			const navAnnotationSelector = '.nav-links [data-nav-link].active';
			const inlineHighlightParents = new Set(['STRONG', 'B', 'EM', 'I']);
			let resizeTimer;
			let fontsRefreshComplete = false;
			const initialFontsLoaded = document.fonts?.status === 'loaded';

			const getHighlightHost = (link) => {
				const parent = link.parentElement;
				if (
					parent &&
					inlineHighlightParents.has(parent.tagName) &&
					parent.childNodes.length === 1
				) {
					return parent;
				}

				return link;
			};

			const clearDetachedAnnotationNodes = () => {
				for (const node of document.querySelectorAll('.rough-annotation')) {
					node.remove();
				}
			};

			const clearAnnotations = () => {
				for (const annotation of annotations.splice(0)) {
					annotation.remove();
				}

				clearDetachedAnnotationNodes();
			};

			const renderAnnotations = (animate) => {
				clearAnnotations();

				const navLinks = Array.from(document.querySelectorAll(navAnnotationSelector));
				const highlightLinks = Array.from(document.querySelectorAll(linkHighlightSelector));

				for (const link of navLinks) {
					annotations.push(
						annotate(link, {
							type: 'circle',
							color: '#111111',
							padding: [1, 2, 1, 2],
							strokeWidth: 1.55,
							iterations: 2,
							animationDuration: 420,
							animate,
						}),
					);
				}

				for (const link of highlightLinks) {
					annotations.push(
						annotate(getHighlightHost(link), {
							type: 'highlight',
							color: 'rgba(255, 230, 92, 0.78)',
							multiline: true,
							animationDuration: 800,
							animate,
						}),
					);
				}

				requestAnimationFrame(() => {
					for (const annotation of annotations) {
						annotation.show();
					}
				});
			};

			const handleResize = () => {
				window.clearTimeout(resizeTimer);
				resizeTimer = window.setTimeout(() => {
					renderAnnotations(false);
				}, 120);
			};

			requestAnimationFrame(() => {
				requestAnimationFrame(() => {
					renderAnnotations(true);
				});
			});

			if (document.fonts?.ready && !initialFontsLoaded) {
				document.fonts.ready.then(() => {
					if (fontsRefreshComplete) {
						return;
					}

					fontsRefreshComplete = true;
					renderAnnotations(false);
				});
			}

			window.addEventListener('resize', handleResize);
			window.addEventListener('pageshow', (event) => {
				if (!event.persisted) {
					return;
				}

				renderAnnotations(false);
			});
		</script>
	</body>
</html>
