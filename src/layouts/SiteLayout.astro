---
import type { ImageMetadata } from 'astro';
import { BACKGROUND_CONFIG } from '../background.config';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_CONFIG } from '../site.config';

interface Props {
	title?: string;
	description?: string;
	image?: ImageMetadata;
	pageClass?: string;
}

const { title, description, image, pageClass = '' } = Astro.props;
const pageTitle = title?.trim() || SITE_CONFIG.title;
const pageDescription = description?.trim() || SITE_CONFIG.description;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} image={image} />
	</head>
	<body class={pageClass}>
		<div class="site-background" aria-hidden="true">
			<div class="site-background__wash"></div>
			<canvas class="site-background__canvas"></canvas>
		</div>
		<div class="page-frame">
			<Header />
			<main class="page-content">
				<slot />
			</main>
			<Footer />
		</div>
		<script is:inline define:vars={{ backgroundConfig: BACKGROUND_CONFIG }}>
			(() => {
				const canvas = document.querySelector('.site-background__canvas');
				if (!(canvas instanceof HTMLCanvasElement)) return;

				const context = canvas.getContext('2d');
				if (!context) return;

				const mediaQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
				const pointer = {
					x: 0,
					y: 0,
					targetX: 0,
					targetY: 0,
					active: false,
					strength: 0,
				};

				let width = 0;
				let height = 0;
				let dpr = 1;
				let nodes = [];
				let frameId = 0;

				const reach = backgroundConfig.reach;
				const pointerReach = backgroundConfig.pointerReach;
				const nodeDensity = backgroundConfig.nodeDensity;
				const maxNodes = backgroundConfig.maxNodes;
				const velocity = backgroundConfig.velocity;
				const nodeOpacity = backgroundConfig.nodeOpacity;
				const lineOpacity = backgroundConfig.lineOpacity;
				const pointerLineOpacity = backgroundConfig.pointerLineOpacity;
				const pointerNodeOpacity = backgroundConfig.pointerNodeOpacity;
				const particleColor = '0, 0, 0';

				const createNode = () => ({
					x: Math.random() * width,
					y: Math.random() * height,
					vx: (Math.random() - 0.5) * velocity,
					vy: (Math.random() - 0.5) * velocity,
					radius: 1 + Math.random() * 0.85,
				});

				const rebuildNodes = () => {
					const count = Math.min(maxNodes, Math.max(38, Math.round(width * height * nodeDensity)));
					nodes = Array.from({ length: count }, () => createNode());
				};

				const resize = () => {
					width = Math.max(320, Math.floor(window.innerWidth));
					height = Math.max(260, Math.floor(window.innerHeight));
					dpr = Math.min(window.devicePixelRatio || 1, 2);
					canvas.width = Math.round(width * dpr);
					canvas.height = Math.round(height * dpr);
					canvas.style.width = `${width}px`;
					canvas.style.height = `${height}px`;
					context.setTransform(dpr, 0, 0, dpr, 0, 0);
					rebuildNodes();
				};

				const onPointerMove = (event) => {
					pointer.targetX = event.clientX;
					pointer.targetY = event.clientY;
					if (!pointer.active) {
						pointer.x = event.clientX;
						pointer.y = event.clientY;
					}
					pointer.active = true;
				};

				const onPointerLeave = () => {
					pointer.active = false;
				};

				const draw = () => {
					frameId = window.requestAnimationFrame(draw);
					context.clearRect(0, 0, width, height);

					const easing = mediaQuery.matches ? 1 : 0.24;
					pointer.x += (pointer.targetX - pointer.x) * easing;
					pointer.y += (pointer.targetY - pointer.y) * easing;
					pointer.strength += ((pointer.active ? 1 : 0) - pointer.strength) * 0.14;

					for (let i = 0; i < nodes.length; i += 1) {
						const node = nodes[i];
						if (!mediaQuery.matches) {
							node.x += node.vx;
							node.y += node.vy;

							if (node.x < -12) node.x = width + 12;
							if (node.x > width + 12) node.x = -12;
							if (node.y < -12) node.y = height + 12;
							if (node.y > height + 12) node.y = -12;
						}

						context.beginPath();
						context.fillStyle = `rgba(${particleColor}, ${nodeOpacity})`;
						context.arc(node.x, node.y, node.radius, 0, Math.PI * 2);
						context.fill();

						for (let j = i + 1; j < nodes.length; j += 1) {
							const neighbor = nodes[j];
							const dx = neighbor.x - node.x;
							const dy = neighbor.y - node.y;
							const distance = Math.hypot(dx, dy);
							if (distance > reach) continue;

							const lineAlpha = (1 - distance / reach) * lineOpacity;
							context.beginPath();
							context.moveTo(node.x, node.y);
							context.lineTo(neighbor.x, neighbor.y);
							context.strokeStyle = `rgba(${particleColor}, ${lineAlpha})`;
							context.lineWidth = 0.75;
							context.stroke();
						}

						if (pointer.strength < 0.02) continue;

						const pointerDx = pointer.x - node.x;
						const pointerDy = pointer.y - node.y;
						const pointerDistance = Math.hypot(pointerDx, pointerDy);
						if (pointerDistance > pointerReach) continue;

						const pointerAlpha =
							(1 - pointerDistance / pointerReach) * pointerLineOpacity * pointer.strength;
						context.beginPath();
						context.moveTo(node.x, node.y);
						context.lineTo(pointer.x, pointer.y);
						context.strokeStyle = `rgba(${particleColor}, ${pointerAlpha})`;
						context.lineWidth = 0.9;
						context.stroke();

						context.beginPath();
						context.fillStyle = `rgba(${particleColor}, ${pointerNodeOpacity * pointer.strength})`;
						context.arc(node.x, node.y, node.radius + 0.45, 0, Math.PI * 2);
						context.fill();
					}
				};

				window.addEventListener('resize', resize);
				window.addEventListener('pointermove', onPointerMove, { passive: true });
				window.addEventListener('pointerleave', onPointerLeave);

				resize();
				draw();

				window.addEventListener(
					'beforeunload',
					() => {
						window.cancelAnimationFrame(frameId);
						window.removeEventListener('resize', resize);
						window.removeEventListener('pointermove', onPointerMove);
						window.removeEventListener('pointerleave', onPointerLeave);
					},
					{ once: true },
				);
			})();
		</script>
	</body>
</html>
