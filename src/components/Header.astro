---
import { SITE_CONFIG } from '../site.config';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav class="nav-panel panel" aria-label="Primary">
		<a class="brand-lockup" href="/">
			<span class="brand-title">{SITE_CONFIG.title}</span>
		</a>
		<div class="nav-links">
			{
				SITE_CONFIG.nav.map((item) => (
					<HeaderLink href={item.href}>{item.label}</HeaderLink>
				))
			}
		</div>
	</nav>
	<script>
		import { annotate } from 'rough-notation';

		const setupNavAnnotations = () => {
			const nav = document.querySelector('.nav-links');
			if (!nav || nav.dataset.navAnnotationsReady === 'true') {
				return;
			}

			nav.dataset.navAnnotationsReady = 'true';
			const links = Array.from(nav.querySelectorAll('[data-nav-link].active'));

			for (const link of links) {
				const annotation = annotate(link, {
					type: 'circle',
					color: '#111111',
					padding: [1, 2, 1, 2],
					strokeWidth: 1.55,
					iterations: 2,
					animationDuration: 420,
					animate: true,
				});

				requestAnimationFrame(() => {
					annotation.show();
				});
			}
		};

		setupNavAnnotations();
	</script>
</header>
