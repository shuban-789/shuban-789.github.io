---
import type { CollectionEntry } from 'astro:content';
import TagChip from './TagChip.astro';

interface Props {
	post: CollectionEntry<'blog'>;
	compact?: boolean;
}

const { post, compact = false } = Astro.props;
---

<article class:list={['post-card', 'panel', { compact }]}>
	<a class="post-card__link" href={`/blog/${post.id}/`}>
		<h3>{post.data.title}</h3>
		<p class="post-card__description">{post.data.description}</p>
		<div class="tag-row">
			{post.data.tags.map((tag) => <TagChip tag={tag} />)}
		</div>
	</a>
</article>
