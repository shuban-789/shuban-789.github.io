---
import { getEntry, render } from 'astro:content';
import MarkdownPage from '../layouts/MarkdownPage.astro';

const page = await getEntry('pages', 'about');
if (!page) {
	throw new Error('Missing src/content/pages/about.md');
}

const { Content } = await render(page);
---

<MarkdownPage {...page.data}>
	<Content />
</MarkdownPage>
