---
import { getEntry, render } from 'astro:content';
import MarkdownPage from '../layouts/MarkdownPage.astro';

const home = await getEntry('pages', 'home');
if (!home) {
	throw new Error('Missing src/content/pages/home.md');
}

const { Content } = await render(home);
---

<MarkdownPage {...home.data} isHome>
	<Content />
</MarkdownPage>
