&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="n">PS1&lt;/span>&lt;span class="o">=&lt;/span>\&lt;span class="p">[&lt;/span>\&lt;span class="n">e&lt;/span>&lt;span class="p">[&lt;/span>&lt;span class="mi">35&lt;/span>&lt;span class="n">m&lt;/span>\&lt;span class="p">]&lt;/span>\&lt;span class="n">u&lt;/span>\&lt;span class="p">[&lt;/span>\&lt;span class="n">e&lt;/span>&lt;span class="p">[&lt;/span>&lt;span class="n">m&lt;/span>\&lt;span class="p">]&lt;/span>&lt;span class="err">@&lt;/span>\&lt;span class="p">[&lt;/span>\&lt;span class="n">e&lt;/span>&lt;span class="p">[&lt;/span>&lt;span class="mi">35&lt;/span>&lt;span class="n">m&lt;/span>\&lt;span class="p">]&lt;/span>&lt;span class="n">pico&lt;/span>&lt;span class="o">-&lt;/span>&lt;span class="n">chall&lt;/span>\&lt;span class="p">[&lt;/span>\&lt;span class="n">e&lt;/span>&lt;span class="p">[&lt;/span>&lt;span class="n">m&lt;/span>\&lt;span class="p">]&lt;/span>&lt;span class="o">$&lt;/span> &lt;span class="n">SSH_CLIENT&lt;/span>&lt;span class="o">=&lt;/span>&lt;span class="mf">127.0&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="mf">0.1&lt;/span> &lt;span class="mi">55826&lt;/span> &lt;span class="mi">22&lt;/span>
